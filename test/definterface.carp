(load "Test.carp")
(use Test)

;; 1. Legacy Single-Arity Interface
(definterface simple-id (Fn [a] a))
(defn simple-id [x] x)
(implements simple-id simple-id)

;; 2. Protocol with multiple members and varying arities
(definterface MyEq
  [(my-equal? (Fn [(Ref a) (Ref a)] Bool))
   (my-not-equal? (Fn [(Ref a) (Ref a)] Bool))
   (my-hash (Fn [(Ref a)] Int))])

(deftype Person [name String id Int])

(defn my-equal? [a b] 
  (and (Int.= @(Person.id a) @(Person.id b))
       (String.= (Person.name a) (Person.name b))))

(defn my-not-equal? [a b] (not (my-equal? a b)))

(defn my-hash [p] @(Person.id p))

;; Register implementations
(implements my-equal? my-equal?)
(implements my-not-equal? my-not-equal?)
(implements my-hash my-hash)

;; Grouped implementation check
(implements Person MyEq)

;; 3. Another Protocol
(definterface Greeter
  [(say-hi (Fn [(Ref a)] ()))
   (say-bye (Fn [(Ref a)] ()))])

(defn say-hi [p] (println* "Hi " (Person.name p)))
(defn say-bye [p] (println* "Bye " (Person.name p)))

(implements say-hi say-hi)
(implements say-bye say-bye)
(implements Person Greeter)

(deftest test
  (let [p1 (Person.init @"sqrew" 1)
        p2 (Person.init @"sqrew" 1)
        p3 (Person.init @"other" 2)
        t1 (assert-equal test 10 (simple-id 10) "Legacy works")
        t2 (assert-true (ref t1) (my-equal? &p1 &p2) "Arity 2 true")
        t3 (assert-false (ref t2) (my-equal? &p1 &p3) "Arity 2 false")
        t4 (assert-true (ref t3) (my-not-equal? &p1 &p3) "Arity 2 not-equal")
        t5 (assert-equal (ref t4) 1 (my-hash &p1) "Arity 1 works")]
    (do
      (say-hi &p1)
      (say-bye &p1)
      (assert-true (ref t5) true "Greeter dispatch ok")))
)
