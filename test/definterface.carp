(load "Test.carp")
(use Test)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 1. Legacy Behavior (Must Remain Intact)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface id (Fn [a] a))
(defn id [x] x)
(implements id id)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 2. Basic Protocol (Multi-Member Interface)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Eq
  [(eq (Fn [(Ref a) (Ref a)] Bool))
   (neq (Fn [(Ref a) (Ref a)] Bool))])

(deftype Person [id Int])

(defn eq [a b]
  (Int.= @(Person.id a) @(Person.id b)))

(defn neq [a b]
  (not (eq a b)))

;; Register members individually (legacy style still allowed)
(implements eq eq)
(implements neq neq)

;; Atomic protocol implementation
(implements Person Eq)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Sections 3, 4, 5, 10, 11 are moved to separate error tests
;; in test/test-for-errors/protocol_*.carp
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 6. Type Parameter Handling
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Show
  [(show (Fn [a] String))])

(defn show [x] @"ok")
(implements show show)

(implements Person Show Eq)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 7. Isolation Between Types
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Only
  [(get (Fn [a] Int))])

(deftype A [])
(deftype B [])

(defn get [x] 7)
(implements get get)

(implements A Only)

;; B should NOT implicitly implement Only

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 8. Late Definition (Order Independence)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deftype Late [])

(defn late-fn [x] 5)

(definterface LateProto
  [(late-fn (Fn [a] Int))])

(implements late-fn late-fn)
(implements Late LateProto)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 9. Member Name Reuse Across Protocols (NO dispatch magic)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface P1 [(f (Fn [a] Int))])
(definterface P2 [(f (Fn [a] Int))])

(deftype X [])

(defn f [x] 99)

(implements f f)
(implements X P1)
(implements X P2)

;; IMPORTANT:
;; This should NOT introduce protocol-based dispatch.
;; Behavior is whatever global resolution does.

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 12. Runtime Behavior Sanity Check
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deftest test
  (let [p1 (Person.init 1)
        p2 (Person.init 1)
        p3 (Person.init 2)
        x  (X.init)
        a  (A.init)
        l  (Late.init)

        t1 (assert-equal test 10 (id 10) "legacy id")

        t2 (assert-true (ref t1) (eq &p1 &p2) "eq true")
        t3 (assert-false (ref t2) (eq &p1 &p3) "eq false")
        t4 (assert-true (ref t3) (neq &p1 &p3) "neq works")

        t5 (assert-equal (ref t4) &@"ok" &(show p1) "show works")

        t6 (assert-equal (ref t5) 7 (get a) "isolation works")

        t7 (assert-equal (ref t6) 5 (late-fn l) "late works")

        t8 (assert-equal (ref t7) 99 (f x) "no protocol dispatch magic")]
    t8))
