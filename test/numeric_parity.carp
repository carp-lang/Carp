(load "Test.carp")
(use Test)

(deftest test
  ;; Int
  (assert-true test (Int.positive? 1) "Int.positive? 1")
  (assert-false test (Int.positive? 0) "Int.positive? 0")
  (assert-false test (Int.positive? -1) "Int.positive? -1")
  (assert-true test (Int.negative? -1) "Int.negative? -1")
  (assert-false test (Int.negative? 0) "Int.negative? 0")
  (assert-false test (Int.negative? 1) "Int.negative? 1")

  ;; Long
  (assert-true test (Long.positive? 1l) "Long.positive? 1l")
  (assert-false test (Long.positive? 0l) "Long.positive? 0l")
  (assert-false test (Long.positive? -1l) "Long.positive? -1l")
  (assert-true test (Long.negative? -1l) "Long.negative? -1l")
  (assert-false test (Long.negative? 0l) "Long.negative? 0l")
  (assert-false test (Long.negative? 1l) "Long.negative? 1l")
  (assert-true test (Long.even? 2l) "Long.even? 2l")
  (assert-false test (Long.even? 1l) "Long.even? 1l")
  (assert-true test (Long.odd? 1l) "Long.odd? 1l")
  (assert-false test (Long.odd? 2l) "Long.odd? 2l")
  (assert-equal test 5l (Long.clamp 0l 10l 5l) "Long.clamp in range")
  (assert-equal test 0l (Long.clamp 0l 10l -5l) "Long.clamp below range")
  (assert-equal test 10l (Long.clamp 0l 10l 15l) "Long.clamp above range")
  (assert-equal test 1l (Long.sign 5l) "Long.sign positive")
  (assert-equal test -1l (Long.sign -5l) "Long.sign negative")
  (assert-equal test 0l (Long.sign 0l) "Long.sign zero")
  (assert-equal test 0l (Long.zero) "Long.zero")

  ;; Float
  (assert-true test (Float.positive? 1.0f) "Float.positive? 1.0f")
  (assert-false test (Float.positive? 0.0f) "Float.positive? 0.0f")
  (assert-false test (Float.positive? -1.0f) "Float.positive? -1.0f")
  (assert-true test (Float.negative? -1.0f) "Float.negative? -1.0f")
  (assert-false test (Float.negative? 0.0f) "Float.negative? 0.0f")
  (assert-false test (Float.negative? 1.0f) "Float.negative? 1.0f")

  ;; Double
  (assert-true test (Double.positive? 1.0) "Double.positive? 1.0")
  (assert-false test (Double.positive? 0.0) "Double.positive? 0.0")
  (assert-false test (Double.positive? -1.0) "Double.positive? -1.0")
  (assert-true test (Double.negative? -1.0) "Double.negative? -1.0")
  (assert-false test (Double.negative? 0.0) "Double.negative? 0.0")
  (assert-false test (Double.negative? 1.0) "Double.negative? 1.0")
)
