(Project.no-echo)

(deftype A [b (Maybe (Box B))])
(deftype B [a (Maybe (Box A)) value Int])

(defn main []
  (let [a (A.init (Maybe.Just (Box.init (B.init (Maybe.Nothing) 7))))]
    (do (match-ref (A.b &a)
          (Maybe.Just boxb) (IO.println &(str (B.value (Box.peek boxb))))
          _ (IO.println "none"))
        0))
  )
