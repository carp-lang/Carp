(load "Test.carp")
(use Test)

;; 2. Extended Multi-Member Interface (Protocol) with UNIQUE names
(definterface MyEq
  (my-equal? [a a] Bool)
  (my-not-equal? [a a] Bool))

;; 3. Grouped Implementation for Int
(implements MyEq Int
  (defn my-equal? [a b] (Int.= a b))
  (defn my-not-equal? [a b] (not (Int.= a b))))

(deftest test
  (let-do [x 10 y 20
           t1 (assert-false test (my-equal? x y) "Int.my-equal? (grouped) works - false case")
           t2 (assert-true (ref t1) (my-not-equal? x y) "Int.my-not-equal? (grouped) works - true case")
           t3 (assert-true (ref t2) (my-equal? x x) "Int.my-equal? (grouped) works - true case")]
    t3)
)
