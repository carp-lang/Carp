;; Test Interfaces

(load "Test.carp")
(use Test)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 1. Legacy Behavior
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface id (Fn [a] a))
(defn id [x] x)
(implements id id)

(definterface foo (Fn [a] Int))

;; A module implements an interface using implements.
;; Implementations don't need to share names with interfaces.
(defmodule LegacyA
  (defn bar [x] x)
  (implements foo LegacyA.bar))

;; Implementations may be declared before definitions
;; like `doc`, the name is relative to the module environment
(defmodule LegacyB
  (implements foo baz)
  (defn baz [y] (if y 5 0)))

;; Interfaces may be implemented retroactively
;; global functions can also implement interfaces.
(sig gojira (Fn [&String] String))
(defn gojira [s] @s)
(implements monster gojira)

(definterface monster (Fn [a] String))

;; An interface name can be used as a default implementation
(defn monster [scary?] (if scary? @"RAWR" @"meow"))
(implements monster monster)

;; If multiple implementations of the same concrete type are provided,
;; one overwrites the other.
(defn laugh-monster [times] (String.repeat times "LOL"))
(implements monster laugh-monster)
(defn pikachu [times] (String.repeat times "pika"))
(implements monster pikachu)

;; issue #1414, make sure we don't overwrite the lookup mode of implementations
(definterface FOO a)
(defmodule FooModule
  (register FOO Int "CARP_INT_MAX")
  (implements FOO FOO)
)
(defmodule BarModule
  (defn bar []
    FOO)
)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 2. Basic Protocol (Multi-Member Interface)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Eq
  [(eq (Fn [(Ref a) (Ref a)] Bool))
   (neq (Fn [(Ref a) (Ref a)] Bool))])

(deftype Person [id Int])

(defn person-eq [a b]
  (Int.= @(Person.id a) @(Person.id b)))

(defn person-eq-val [a b]
  (person-eq &a &b))
(implements = person-eq-val)

(defn eq [a b]
  (person-eq a b))

(defn neq [a b]
  (not (eq a b)))

;; Register members individually (legacy style still allowed)
(implements eq eq)
(implements neq neq)

;; Atomic protocol implementation
(implements Person Eq)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 3. Type Parameter Handling
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Show
  [(show (Fn [a] String))])

(defn show [x] @"ok")
(implements show show)

(implements Person Show Eq)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 4. Isolation Between Types
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Only
  [(get (Fn [a] Int))])

(deftype IsolationA [])
(deftype IsolationB [])

(defn get [x] 7)
(implements get get)

(implements IsolationA Only)

;; IsolationB should NOT implicitly implement Only

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 5. Late Definition (Order Independence)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deftype Late [])

(defn late-fn [x] 5)

(definterface LateProto
  [(late-fn (Fn [a] Int))])

(implements late-fn late-fn)
(implements Late LateProto)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 6. Member Name Reuse Across Protocols (NO dispatch magic)
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface P1 [(f (Fn [a] Int))])
(definterface P2 [(f (Fn [a] Int))])

(deftype X [])

(defn f [x] 99)

(implements f f)
(implements X P1)
(implements X P2)

;; Implement Eq for Int as well so it can be used in Box
(defmodule Int
  (defn eq [a b] (Int.= @a @b))
  (defn neq [a b] (Int./= @a @b))
  (implements eq Int.eq)
  (implements neq Int.neq)
)
(implements Int Eq)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 7. Generic Types
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deftype (MyBox a) [inner a])

(defn mybox-eq [a b]
  (eq (MyBox.inner a) (MyBox.inner b)))
(implements eq mybox-eq)

(implements (MyBox a) Eq)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 8. Complex Signatures
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Container
  [(put-many (Fn [a (Array Int)] a))
   (get-maybe (Fn [(Ref a)] (Maybe Int)))])

(deftype IntContainer [val Int])

(defn put-many [c arr]
  (IntContainer.set-val c (Int.+ @(IntContainer.val &c) (Array.sum &arr))))
(implements put-many put-many)

(defn get-maybe [c]
  (Maybe.Just @(IntContainer.val c)))
(implements get-maybe get-maybe)

(implements IntContainer Container)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 9. Different Type Variable Names
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface DiffVar
  [(diff (Fn [(Ref b)] (Ref b)))])

(deftype DiffType [])
(sig diff-eq (Fn [(Ref DiffType), (Ref DiffType)] Bool))
(defn diff-eq [a b] true)
(implements = diff-eq)
(sig diff (Fn [(Ref a)] (Ref a)))
(defn diff [x] x)
(implements diff diff)

(implements DiffType DiffVar)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 10. Type Variable Name Sensitivity
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Interfaces may use any type variable name ('b' here instead of 'a').
;; Protocol implementation verification must handle arbitrary type variable
;; names correctly, not just 'a'.
(definterface DiffVar2
  [(diff2 (Fn [(Ref b)] (Ref b)))])

(deftype DiffType2 [])
(sig diff2-eq (Fn [(Ref DiffType2), (Ref DiffType2)] Bool))
(defn diff2-eq [a b] true)
(implements = diff2-eq)
(sig diff2 (Fn [(Ref DiffType2)] (Ref DiffType2)))
(defn diff2 [x] x)
(implements diff2 diff2)

(implements DiffType2 DiffVar2)

;; 'a' is the conventional type variable name; verify it works as expected.
(definterface DiffVar3
  [(diff3 (Fn [(Ref a)] (Ref a)))])

(deftype DiffType3 [])
(sig diff3-eq (Fn [(Ref DiffType3), (Ref DiffType3)] Bool))
(defn diff3-eq [a b] true)
(implements = diff3-eq)
(sig diff3 (Fn [(Ref DiffType3)] (Ref DiffType3)))
(defn diff3 [x] x)
(implements diff3 diff3)

(implements DiffType3 DiffVar3)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 11. Single-member Protocol
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(definterface Wrap
  [(wrap (Fn [a] a))])

(deftype Wrapper [])

(defn wrap [x] x)
(implements wrap wrap)
(implements Wrapper Wrap)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 12. Runtime Behavior Sanity Check
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(deftest test
  (let [p1 (Person.init 1)
        p2 (Person.init 1)
        p3 (Person.init 2)
        x  (X.init)
        isoA (IsolationA.init)
        l  (Late.init)
        b1 (MyBox.init 10)
        b2 (MyBox.init 10)
        b3 (MyBox.init 20)
        ic (IntContainer.init 42)
        dt (DiffType.init)
        dt2 (DiffType2.init)
        dt3 (DiffType3.init)
        t1 (assert-equal test 10 (id 10) "legacy id")
        t2 (assert-equal (ref t1) &2 &(foo 2) "Implements works as expected.")
        t3 (assert-equal (ref t2) &5 &(foo true) "Implementations can be declared before definitions.")
        t4 (assert-equal (ref t3) "SKRYEEE" &(monster "SKRYEEE") "Interfaces can be implemented retroactively.")
        t5 (assert-equal (ref t4) "meow" &(monster false) "Implementations may be used as a default.")
        t6 (assert-equal (ref t5) "pikapikapika" &(monster 3) "Implementations may be overwritten.")
        t7 (assert-equal (ref t6) Int.MAX (BarModule.bar) "regression for issue #1414")
        t8 (assert-true (ref t7) (eq &p1 &p2) "eq true")
        t9 (assert-false (ref t8) (eq &p1 &p3) "eq false")
        t10 (assert-true (ref t9) (neq &p1 &p3) "neq works")
        t11 (assert-equal (ref t10) &@"ok" &(show p1) "show works")
        t12 (assert-equal (ref t11) 7 (get isoA) "isolation works")
        t13 (assert-equal (ref t12) 5 (late-fn l) "late works")
        t14 (assert-equal (ref t13) 99 (f x) "no protocol dispatch magic")
        t15 (assert-true (ref t14) (eq &b1 &b2) "generic box eq true")
        t16 (assert-false (ref t15) (eq &b1 &b3) "generic box eq false")
        t17 (assert-equal (ref t16) &(Maybe.Just 42) &(get-maybe &ic) "complex sig member 2 works")
        ic2 (put-many ic [3 5])
        t18 (assert-equal (ref t17) 50 @(IntContainer.val &ic2) "complex sig member 1 works")
        t19 (assert-equal (ref t18) &dt (diff &dt) "different type variable name works (generic impl)")
        t20 (assert-equal (ref t19) &dt2 (diff2 &dt2) "different type variable name works (concrete impl)")
        t21 (assert-equal (ref t20) &dt3 (diff3 &dt3) "standard 'a' type variable works")
        t22 (assert-equal (ref t21) 42 (wrap 42) "single-member list form works")]
    t22))
