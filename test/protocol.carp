(load-and-use Test)

(deftype Person
  [name String
   age Int])

(defprotocol Show
  [(show (Fn [(Ref a)] String))])

(impl-for Person Show
  (defn show [p]
    (String.concat
      &[@(Person.name p)
        @" ("
        (Int.str @(Person.age p))
        @")"])))

(deftest test
  (let [p (Person.init @"Nick" 35)]
    (assert-equal test
                  &@"Nick (35)"
                  &(show &p)
                  "Protocols with impl-for work as expected")))
